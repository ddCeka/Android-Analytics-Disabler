        dodis $CMD "com.teslacoilsw.launcher/com.android.launcher3.MemoryDumpActivity"
        dodis $CMD "com.teslacoilsw.launcher/org.matomo.sdk.extra.InstallReferrerReceiver"
    fi
    if [ "$i" == "com.telkomsel.telkomselcm" ]; then
        dodis $CMD "com.telkomsel.telkomselcm/com.useinsider.insider.InsiderActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.useinsider.insider.InsiderInappActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.useinsider.insider.InsiderLoginActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.google.android.gms.ads.OutOfContextTestingActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.google.android.tv.ads.controls.FallbackImageActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.dashboard.ads.detailads.view.DetailAdsTemplateOneActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.dashboard.ads.detailads.view.DetailAdsTemplateTwoActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.dashboard.ads.detailads.view.DetailAdsVideoActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.view.dailycheckinrevampnew.ads.all.DciAdsAllActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.view.dailycheckinrevampnew.ads.DciVastAdsVideoPlayerActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.view.dailycheckinrevampnew.ads.video.DciVideoAdsActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.view.flexibleshowtime.VasPromoDigiAdsActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.view.shop.myads.MyAdsActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.telkomsel.mytelkomsel.view.shop.packages.myads.PackageDetailsMyAdsActivity"
        dodis $CMD "com.telkomsel.telkomselcm/com.huawei.agconnect.core.ServiceDiscovery"
        dodis $CMD "com.telkomsel.telkomselcm/com.useinsider.insider.GifPlayService"
